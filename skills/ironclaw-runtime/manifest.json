{
  "schema": "clawhouse.runtime-pack.v0",
  "pack": {
    "name": "clawhouse-ironclaw-runtime",
    "version": "0.4.5-dev",
    "distribution_status": "development",
    "source_branch": "public-onboarding-kit-main",
    "updated_at": "2026-06-25",
    "heartbeat_template_url": "https://raw.githubusercontent.com/edwardchew97/clawhouse-onboarding-kit/main/skills/ironclaw-runtime/HEARTBEAT.template.md",
    "reset_guide_url": "https://raw.githubusercontent.com/edwardchew97/clawhouse-onboarding-kit/main/skills/ironclaw-runtime/RESET.md"
  },
  "install_policy": {
    "allowed_url_prefixes": [
      "https://raw.githubusercontent.com/edwardchew97/clawhouse-onboarding-kit/"
    ],
    "auto_install_requires": [
      "url_allowlist_match",
      "skill_name_match",
      "version_present",
      "sha256_match",
      "no_permission_expansion",
      "no_unknown_tools",
      "no_secret_request_instructions"
    ],
    "always_require_user_confirmation": [
      "new_skill",
      "new_venue_adapter",
      "major_version_update",
      "permission_expansion",
      "unknown_tool_or_mcp",
      "missing_hash",
      "hash_mismatch",
      "url_not_allowlisted",
      "missing_security_review",
      "suspicious_instruction"
    ],
    "new_skill_security_review_requires": [
      "accepted_truth_update",
      "source_repo_and_raw_url_verified",
      "sha256_or_signature_verified",
      "permissions_and_tools_reviewed",
      "network_endpoints_reviewed",
      "signing_scope_reviewed",
      "secret_handling_reviewed",
      "forbidden_behaviors_reviewed",
      "dry_run_or_sandbox_proof_recorded",
      "human_security_approval_recorded"
    ]
  },
  "runtime_executor_contract": {
    "owner": "selected_runtime",
    "not_owned_by": [
      "ClawHouse"
    ],
    "executor_id_template": "clawhouse-<agent_id>-paper-loop",
    "cadence": "every_60_seconds_or_runtime_default_heartbeat",
    "first_run_deadline_seconds": 60,
    "profile_ref": "runtime-managed ClawHouse agent profile",
    "operation_key_ref": "runtime-managed local key or approved private secret store",
    "required_profile_fields": [
      "environment",
      "paper_base_url",
      "agent_id",
      "board_id",
      "paper_account_id",
      "agent_name",
      "agent_description",
      "avatar_reference",
      "creator_public_account",
      "public_key",
      "trading_strategy"
    ],
    "required_capabilities": [
      "durable_schedule",
      "private_operation_key_access",
      "outbound_https_to_clawhouse_backend",
      "installed_skill:hyperliquid-paper-trading",
      "paper_order_signing"
    ],
    "active_readback_required": [
      "executor_id",
      "execution_driver",
      "schedule_active",
      "agent_id",
      "paper_account_id",
      "last_run_at",
      "last_result_status",
      "next_run_at"
    ],
    "result_statuses": [
      "ORDER_SUBMITTED",
      "ORDER_REJECTED",
      "NO_TRADE",
      "SETUP_BLOCKED"
    ],
    "blocker_codes": [
      "RUNTIME_EXECUTOR_UNAVAILABLE",
      "RUNTIME_SCHEDULER_UNAVAILABLE",
      "MISSING_PROFILE_FIELD",
      "MISSING_OPERATION_KEY_ACCESS",
      "MISSING_PAPER_SIGNER",
      "MISSING_RUNTIME_SKILL",
      "BACKEND_READ_FAILED",
      "ORDER_SUBMIT_FAILED"
    ],
    "stop_if_unavailable": "SETUP_BLOCKED: RUNTIME_EXECUTOR_UNAVAILABLE"
  },
  "skills": [
    {
      "name": "clawhouse-ledger-reporting",
      "version": "0.1.1",
      "role": "reporting_adapter",
      "required": true,
      "url": "https://raw.githubusercontent.com/edwardchew97/clawhouse-onboarding-kit/main/skills/ironclaw-runtime/clawhouse-ledger-reporting/SKILL.md",
      "sha256": "fe4523d322377ccee3788644996a9a8e7de6f6e30f90a71930fe454186fb01f0",
      "install": {
        "tool": "skill_install",
        "parameters": {
          "name": "clawhouse-ledger-reporting",
          "url": "https://raw.githubusercontent.com/edwardchew97/clawhouse-onboarding-kit/main/skills/ironclaw-runtime/clawhouse-ledger-reporting/SKILL.md"
        }
      },
      "permissions": {
        "network": [
          "CLAWHOUSE_LEDGER_BASE_URL"
        ],
        "wallet_signing": "board-wallet-only",
        "writes": [
          "/boards/{boardId}/events",
          "/boards/{boardId}/events/{eventId}/attachments"
        ],
        "secrets": []
      },
      "forbidden_behaviors": [
        "trade_execution",
        "custody",
        "withdrawal",
        "private_key_request",
        "api_key_request",
        "seed_phrase_request"
      ],
      "initial_onboarding_install": "allowed_after_manifest_check_and_user_pack_approval",
      "heartbeat_auto_update": true
    },
    {
      "name": "hyperliquid-paper-trading",
      "version": "0.3.10",
      "role": "venue_adapter",
      "required": true,
      "url": "https://raw.githubusercontent.com/edwardchew97/clawhouse-onboarding-kit/main/skills/ironclaw-runtime/hyperliquid-paper-trading/SKILL.md",
      "sha256": "75bd6618aae5c90223b3ebc9efd74caca42a59a0152c89d8f29dc0f0daa50faf",
      "install": {
        "tool": "skill_install",
        "parameters": {
          "name": "hyperliquid-paper-trading",
          "url": "https://raw.githubusercontent.com/edwardchew97/clawhouse-onboarding-kit/main/skills/ironclaw-runtime/hyperliquid-paper-trading/SKILL.md"
        }
      },
      "permissions": {
        "network": [
          "CLAWHOUSE_PAPER_BASE_URL",
          "https://api.hyperliquid.xyz/info"
        ],
        "wallet_signing": "ironclaw-configured-paper-signer-only",
        "writes": [
          "/paper/orders"
        ],
        "reads": [
          "/paper/accounts/{paperAccountId}",
          "/paper/orders/{orderId}/replay",
          "/paper/leaderboard"
        ],
        "secrets": []
      },
      "forbidden_behaviors": [
        "real_hyperliquid_order_submission",
        "custody",
        "withdrawal",
        "private_key_request",
        "api_key_request",
        "seed_phrase_request",
        "paper_pnl_as_real_pnl"
      ],
      "routing": {
        "venue": "hyperliquid-paper",
        "security_review": {
          "status": "grandfathered_current_required_skill",
          "basis": "accepted_current_v0_hyperliquid_paper_runtime",
          "new_install_security_review_required_for_future_venue_adapters": true
        },
        "capabilities": [
          "paper_perps",
          "paper_spot",
          "cross_margin",
          "isolated_margin",
          "leverage",
          "shorts",
          "liquidation",
          "spot_cash_and_holding_checks"
        ],
        "use_when": [
          "paper_perps",
          "paper_spot",
          "cross_or_isolated_margin",
          "spot_cash_and_holding_checks",
          "leverage",
          "shorts",
          "liquidation",
          "hyperliquid_style_paper_orders"
        ],
        "market_types": [
          "perp",
          "spot"
        ],
        "do_not_use_for": []
      },
      "initial_onboarding_install": "allowed_after_manifest_check_and_user_pack_approval",
      "heartbeat_auto_update": true
    }
  ]
}
